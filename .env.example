# ──────────────────────────────────────────────────────────────────────────
# HookBudget — Variables d'environnement (exemple)
# Copiez ce fichier en `.env` puis renseignez vos valeurs.
# Le fichier `.env` ne doit JAMAIS être committé (voir .gitignore).
# ──────────────────────────────────────────────────────────────────────────

# Base de données PostgreSQL (utilisée par Prisma)
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/hookbudget?schema=public"

# Better Auth (authentification — non branchée au Sprint 1)
# Générez un secret aléatoire, ex. : openssl rand -base64 32
BETTER_AUTH_SECRET="changez-moi"
BETTER_AUTH_URL="http://localhost:3000"

# URL publique de l'application (accessible côté navigateur)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────
# Fournisseurs sociaux (OPTIONNEL — les boutons Google/GitHub sont déjà dans
# l'UI mais ne sont actifs que si les clés correspondantes sont renseignées).
# Callback à déclarer chez le fournisseur :
#   {BETTER_AUTH_URL}/api/auth/callback/{google|github}
# ──────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ──────────────────────────────────────────────────────────────────────────
# Assistant financier IA (Sprint 13)
# Fournisseur sélectionnable via AI_PROVIDER : anthropic | openai | gemini | mistral
# (par défaut : anthropic). En l'absence de clé, l'assistant bascule sur un
# moteur local déterministe (aucune invention) — le chat reste fonctionnel.
# ──────────────────────────────────────────────────────────────────────────
AI_PROVIDER="anthropic"
AI_MODEL="claude-opus-4-8"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
MISTRAL_API_KEY=""

# ──────────────────────────────────────────────────────────────────────────
# Environnement & observabilité (Sprint 15)
# ──────────────────────────────────────────────────────────────────────────
# development | staging | production
APP_ENV="development"
# debug | info | warn | error
LOG_LEVEL="debug"
# Observabilité (optionnel — activées si renseignées)
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
# Jeton protégeant /api/metrics (optionnel)
METRICS_TOKEN=""
# Promotion SUPER_ADMIN au seed admin (npm run db:seed:admin)
ADMIN_EMAIL=""
